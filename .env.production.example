# =============================================================================
# marketplace — Production (Docker / Linux Mint 22)
# =============================================================================
# cp .env.production.example .env.production
# edit secret, lalu: ./scripts/deploy.sh
# =============================================================================

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=marketplace
APP_PORT=5057

# --- Server (di dalam container) ---
PORT=3000
HOST=0.0.0.0

# --- Auth (wajib — ganti sebelum deploy) ---
JWT_SECRET=ganti-dengan-secret-yang-kuat-minimal-32-karakter

SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=ganti-password-admin-kuat
SEED_ADMIN_NAME=Admin

# --- Google Sign-In (opsional) ---
GOOGLE_CLIENT_ID=

# --- Lalamove Partner API (opsional) ---
LALAMOVE_API_KEY=
LALAMOVE_API_SECRET=
LALAMOVE_SANDBOX=true
LALAMOVE_MARKET=ID

# --- GoSend API mitra (opsional) ---
GOSEND_API_BASE=
GOSEND_CLIENT_ID=
GOSEND_PASS_KEY=
GOSEND_ESTIMATE_PATH=/gokilat/v10/calculate/price?paymentType=3

# --- WhatsApp Chatbot via Fonnte (opsional) ---
FONNTE_API_TOKEN=
WHATSAPP_BOT_NUMBER=

# --- Google Gemini (opsional — untuk balasan otomatis WA) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
