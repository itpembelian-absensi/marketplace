# =============================================================================
# marketplace — Development (lokal)
# =============================================================================
# cp .env.example .env
# npm start
# =============================================================================

# --- Server ---
# Port yang dibuka ke browser (buka-aplikasi.bat & README memakai 5057)
PORT=5057
# Bind address — 127.0.0.1 untuk dev lokal; Docker pakai 0.0.0.0 (diatur compose)
HOST=127.0.0.1

# --- Auth (wajib di production) ---
JWT_SECRET=ganti-dengan-secret-yang-kuat-minimal-32-karakter

# Akun admin pertama — dibuat otomatis saat pertama kali jalan jika email belum ada
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Admin

# --- Google Sign-In (opsional) ---
# Client ID dari Google Cloud Console (OAuth 2.0 Web client)
GOOGLE_CLIENT_ID=

# --- Lalamove Partner API (opsional — tanpa ini dipakai estimasi jarak) ---
# Daftar: https://developers.lalamove.com/
LALAMOVE_API_KEY=
LALAMOVE_API_SECRET=
LALAMOVE_SANDBOX=true
LALAMOVE_MARKET=ID

# --- GoSend API mitra (opsional — tanpa ini dipakai estimasi jarak) ---
# Daftar mitra: https://www.gojek.com/id-id/gosend/api
# Staging: https://ecommercetools-integration.gojek.com
GOSEND_API_BASE=https://ecommercetools-integration.gojek.com
GOSEND_CLIENT_ID=
GOSEND_PASS_KEY=
GOSEND_ESTIMATE_PATH=/gokilat/v10/calculate/price?paymentType=3

# --- WhatsApp Chatbot via Fonnte (opsional) ---
# Aktifkan juga dari panel Admin → WhatsApp Bot
FONNTE_API_TOKEN=
WHATSAPP_BOT_NUMBER=

# --- Google Gemini (opsional — wajib hanya jika bot WA auto-reply diaktifkan) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
